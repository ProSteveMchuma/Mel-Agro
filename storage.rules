rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && (
        (request.auth.token.get('email', '').lower() in [
          'admin@melagri.com', 
          'admin@melagri.co.ke',
          'james.wambua@makamithi.com', 
          'proinnovationtech@gmail.com',
          'shadrack@adifa.co.ke'
        ]) ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.get('role', 'user') in ['admin', 'super-admin']
      );
    }
  }
}
