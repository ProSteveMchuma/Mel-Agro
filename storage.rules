rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && (
        (request.auth.token.get('email', '').lower() in [
          'admin@melagro.com', 
          'admin@mel-agri.com',
          'james.wambua@makamithi.com', 
          'proinnovationtech@gmail.com',
          'shadrack@adifa.co.ke'
        ]) ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super-admin']
      );
    }
  }
}
