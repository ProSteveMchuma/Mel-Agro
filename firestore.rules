rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Robust helper function to check if user is admin or super-admin
    function isAdmin() {
      return request.auth != null && (
        (request.auth.token != null && "email" in request.auth.token && 
         request.auth.token.email.lower() in [
           'proinnovationtech@gmail.com', 
           'admin@melagri.com', 
           'admin@melagri.co.ke',
           'james.wambua@makamithi.com',
           'shadrack@adifa.co.ke'
         ]) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') in ['admin', 'super-admin'])
      );
    }

    // Products: Public read, Admin write, User can decrement stock during checkout
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
      allow update: if request.auth != null && (
        isAdmin() || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stockQuantity', 'inStock'])
      );
    }

    // Inventory History: Admin write, User create (for orders)
    match /inventory_history/{historyId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
      allow create: if request.auth != null;
    }

    // Orders: Users can read/create their own, Admin can read/write all
    match /orders/{orderId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      // Admin can update everything. Users can ONLY update returnStatus/returnReason OR cancel the order OR set checkoutRequestId for M-Pesa
      allow update: if request.auth != null && (
        isAdmin() || (
          resource.data.userId == request.auth.uid && (
            request.resource.data.diff(resource.data).affectedKeys().hasAny(['returnStatus', 'returnReason', 'checkoutRequestId', 'status'])
          )
        )
      );
    }

    // Users: Users can read/update their own profile (excluding sensitive fields),
    // admins can manage all. Role / status / loyaltyPoints can ONLY be changed by an admin
    // (or via the server admin SDK which bypasses these rules).
    match /users/{userId} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if (
        isAdmin() ||
        (request.auth != null && request.auth.uid == userId &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status', 'loyaltyPoints']))
      );
      allow delete: if isAdmin();
    }

    // Transactions: Admin only for read, System/Auth for create
    match /transactions/{id} {
        allow read: if isAdmin();
        allow create: if request.auth != null;
    }

    // Settings: Public read (for shipping rates), Admin write
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Content: Public read, Admin write (for banners etc)
    match /content/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Reviews: Public read, Authenticated create
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Wishlist: Private to user
    match /wishlist/{wishlistId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Notifications: Users can read/write their own, Admin can read/write all
    match /notifications/{notificationId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Messages: Users can create and read own. Admin can read/write all.
    match /messages/{messageId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Analytics: Authenticated-only writes, admin read/delete.
    // We only accept tracking events from signed-in users (anonymous Firebase auth
    // will be set up separately if guest tracking is needed). Bounds doc size to
    // prevent fill-the-bucket abuse.
    function validAnalyticsEvent() {
      return request.resource.data.size() < 50 &&
             request.resource.data.keys().hasAny(['timestamp', 'event', 'term', 'productId', 'page']);
    }
    match /analytics_search_terms/{id} {
      allow read, delete: if isAdmin();
      allow create: if request.auth != null && validAnalyticsEvent();
      allow update: if isAdmin();
    }
    match /analytics_products/{id} {
      allow read, delete: if isAdmin();
      allow create: if request.auth != null && validAnalyticsEvent();
      allow update: if isAdmin();
    }
    match /analytics_traffic/{id} {
      allow read, delete: if isAdmin();
      allow create: if request.auth != null && validAnalyticsEvent();
      allow update: if isAdmin();
    }
    match /analytics_funnels/{id} {
      allow read, delete: if isAdmin();
      allow create, update: if request.auth != null && request.auth.uid == id;
    }
    match /analytics_purchases/{id} {
      allow read, delete: if isAdmin();
      allow create: if request.auth != null;
    }

    // Carts: Private to user
    match /carts/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Discounts/Coupons: Public read, Admin write
    match /discounts/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // M-Pesa C2B payment audit log: written only by server (admin SDK bypasses), admin reads
    match /c2bPayments/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // M-Pesa refunds audit log: written only by server (admin SDK bypasses), admin reads
    match /refunds/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // M-Pesa configuration (C2B URL registration state): admin only
    match /mpesaConfig/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Paystack webhook idempotency log: server only
    match /paystackWebhookEvents/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // AI Insights cache: server-only writes (admin SDK bypasses), admin read
    match /aiInsights/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Bulk inquiry submissions from /bulk page: server-only writes (via API), admin read
    match /bulkInquiries/{id} {
      allow read, update: if isAdmin();
      allow create, delete: if false;
    }

    // Discount usage tracking: server only
    match /discountUsage/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}



