rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Robust helper function to check if user is admin or super-admin
    function isAdmin() {
      return request.auth != null && (
        (request.auth.token.get('email', '').lower() in [
          'proinnovationtech@gmail.com', 
          'admin@melagro.com', 
          'admin@mel-agri.com',
          'james.wambua@makamithi.com',
          'shadrack@adifa.co.ke'
        ]) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super-admin'])
      );
    }

    // Products: Public read, Admin write, User can decrement stock during checkout
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
      allow update: if request.auth != null && (
        isAdmin() || 
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['stockQuantity', 'inStock'])
      );
    }

    // Inventory History: Admin write, User create (for orders)
    match /inventory_history/{historyId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
      allow create: if request.auth != null;
    }

    // Orders: Users can read/create their own, Admin can read/write all
    match /orders/{orderId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      // Admin can update everything. Users can ONLY update returnStatus/returnReason OR cancel the order OR set checkoutRequestId for M-Pesa
      allow update: if request.auth != null && (
        isAdmin() || (
          resource.data.userId == request.auth.uid && (
            request.resource.data.diff(resource.data).affectedKeys().hasAny(['returnStatus', 'returnReason', 'checkoutRequestId', 'status'])
          )
        )
      );
    }

    // Users: Users can read/write their own profile, Admin can read all
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // Transactions: Admin only for read, System/Auth for create
    match /transactions/{id} {
        allow read: if isAdmin();
        allow create: if request.auth != null;
    }

    // Settings: Public read (for shipping rates), Admin write
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Content: Public read, Admin write (for banners etc)
    match /content/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Reviews: Public read, Authenticated create
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Wishlist: Private to user
    match /wishlist/{wishlistId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Notifications: Users can read/write their own, Admin can read/write all
    match /notifications/{notificationId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Messages: Users can create and read own. Admin can read/write all.
    match /messages/{messageId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Analytics: Restricted delete/read, Public write (for tracking)
    match /analytics_search_terms/{id} {
      allow read, delete: if isAdmin();
      allow create, update: if true;
    }
    match /analytics_products/{id} {
      allow read, delete: if isAdmin();
      allow create, update: if true;
    }
    match /analytics_traffic/{id} {
      allow read, delete: if isAdmin();
      allow create, update: if true;
    }
    match /analytics_funnels/{id} {
      allow read, delete: if isAdmin();
      allow create, update: if request.auth != null && request.auth.uid == id;
    }
    match /analytics_purchases/{id} {
      allow read, delete: if isAdmin();
      allow create: if request.auth != null;
    }

    // Carts: Private to user
    match /carts/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Discounts/Coupons: Public read, Admin write
    match /discounts/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}


